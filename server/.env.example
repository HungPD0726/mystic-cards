# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL default)
DB_DIALECT=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mystic_cards

# Optional discrete settings (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mystic_cards
DB_USER=postgres
DB_PASSWORD=postgres

# PostgreSQL SSL
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# MSSQL-only options (only when DB_DIALECT=mssql)
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (required for /api/auth/google-login)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:8080
